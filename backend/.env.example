# Database (MariaDB/MySQL)
DB_HOST=your-db-host.example.com
DB_PORT=3306
DB_DATABASE=budgeteer_master
MASTER_DB_USER=your_master_user
MASTER_DB_PASSWORD=your_master_password

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# Server
PORT=3000
PRODUCTION=false

# Email via Resend (https://resend.com → API Keys + verify budgeteer.money domain).
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=Budgeteer <noreply@budgeteer.money>
ADMIN_NOTIFICATION_EMAIL=surbanwebdev@gmail.com
APP_URL=https://www.budgeteer.money

# Optional: Gmail SMTP for local-only testing (ignored when RESEND_API_KEY is set).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=surbanwebdev@gmail.com
# SMTP_PASSWORD=your_gmail_app_password
