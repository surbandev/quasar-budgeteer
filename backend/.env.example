# Database (MariaDB/MySQL)
DB_HOST=your-db-host.example.com
DB_PORT=3306
DB_DATABASE=budgeteer_master
MASTER_DB_USER=your_master_user
MASTER_DB_PASSWORD=your_master_password

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# Server
PORT=3000
PRODUCTION=false

# Email (SMTP) - used for account-request and account-activated notifications.
# If these are left unset, emails are skipped and logged to the server console.
#
# Gmail setup (recommended): enable 2-Step Verification on the Google account,
# then create an "App Password" (Google Account > Security > App passwords) and
# use that 16-character value as SMTP_PASSWORD (NOT your normal Gmail password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# SMTP_SECURE defaults to true only for port 465; STARTTLS on 587 uses false.
SMTP_SECURE=false
SMTP_USER=surbanwebdev@gmail.com
SMTP_PASSWORD=your_gmail_app_password
# Optional "From" address shown to recipients (defaults to SMTP_USER).
SMTP_FROM=Budgeteer <surbanwebdev@gmail.com>
# Where new-registration request emails are sent (the administrator inbox).
ADMIN_NOTIFICATION_EMAIL=surbanwebdev@gmail.com
