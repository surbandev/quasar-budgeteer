# Local dev against Railway production MySQL (public TCP proxy).
# Copy to backend/.env.railway or run: npm run env:setup:railway
#
# Railway dashboard → MySQL service → Connect → Public network

DB_HOST=reseau.proxy.rlwy.net
DB_PORT=59529
DB_DATABASE=budgeteer
MASTER_DB_USER=root
MASTER_DB_PASSWORD=
DB_SSL=false

# Match JWT_SECRET on the Railway budgeteer service so tokens behave consistently
JWT_SECRET=

PORT=3000
PRODUCTION=false
