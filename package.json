{
  "name": "quasar-budgeteer",
  "version": "0.0.1",
  "description": "A Quasar Project",
  "productName": "Budgeteer",
  "author": "Shawn Urban <surbanwebdev@gmail.com>",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "vitest",
    "test:run": "vitest run && playwright test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:api": "vitest run --config vitest.backend.config.js",
    "dev": "quasar dev",
    "dev:pwa": "quasar dev -m pwa",
    "dev:api": "npm start --prefix backend",
    "dev:all": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev\"",
    "dev:all:railway": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-railway.ps1",
    "env:setup:railway": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-env-railway.ps1",
    "dev:cap": "quasar dev -m capacitor -T android",
    "dev:cap:ios": "quasar dev -m capacitor -T ios",
    "build": "quasar build -m pwa",
    "build:cap": "quasar build -m capacitor -T android",
    "build:cap:ios": "quasar build -m capacitor -T ios",
    "ios:run": "bash scripts/ios.sh run",
    "ios:build": "bash scripts/ios.sh build",
    "deploy": "npx @railway/cli up --detach -y --service budgeteer",
    "db:backup": "node backend/scripts/backup-databases.js",
    "db:restore": "node backend/scripts/restore-databases.js",
    "db:restore:railway": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/restore-to-railway.ps1",
    "db:verify:railway": "node backend/scripts/verify-restore.js",
    "postinstall": "quasar prepare"
  },
  "dependencies": {
    "@quasar/extras": "^1.16.4",
    "axios": "^1.13.2",
    "chart.js": "^4.5.1",
    "luxon": "^3.7.2",
    "mitt": "^3.0.1",
    "pinia": "^3.0.1",
    "quasar": "^2.19.3",
    "register-service-worker": "^1.7.2",
    "vue": "^3.5.22",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.58.2",
    "@quasar/app-vite": "^2.1.0",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.2",
    "concurrently": "^9.2.0",
    "eslint": "^9.14.0",
    "eslint-plugin-vue": "^10.4.0",
    "globals": "^16.4.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.14",
    "prettier": "^3.3.3",
    "vite-plugin-checker": "^0.11.0",
    "vitest": "^4.1.6",
    "vue-eslint-parser": "^10.2.0",
    "workbox-build": "^7.4.1",
    "workbox-cacheable-response": "^7.4.1",
    "workbox-core": "^7.4.1",
    "workbox-expiration": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22 || ^20",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  }
}
