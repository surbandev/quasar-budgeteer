{

  "version": "0.2.0",

  "configurations": [

    {

      "name": "Run",

      "type": "node-terminal",

      "request": "launch",

      "command": "npm run dev:all"

    },

    {

      "name": "Run (Railway DB)",

      "type": "node-terminal",

      "request": "launch",

      "command": "npm run dev:all:railway"

    },

    {

      "name": "Run Vitest",

      "type": "node-terminal",

      "request": "launch",

      "command": "npx vitest run"

    },

    {

      "name": "Run E2E",

      "type": "node-terminal",

      "request": "launch",

      "command": "npm run test:e2e"

    },

    {

      "name": "Run on iOS (device/simulator, macOS)",

      "type": "node-terminal",

      "request": "launch",

      "command": "npm run ios:run"

    },

    {

      "name": "Build iOS + open Xcode (macOS)",

      "type": "node-terminal",

      "request": "launch",

      "command": "npm run ios:build"

    },

    {

      "name": "Deploy",

      "type": "node-terminal",

      "request": "launch",

      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .vscode/deploy.ps1"

    }

  ]

}


