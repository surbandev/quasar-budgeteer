# Copy to keystore.properties (gitignored) after creating a keystore, e.g.:
# keytool -genkey -v -keystore release-key.jks -keyalg RSA -keysize 2048 -validity 10000 -alias budgeteer
#
# storeFile is relative to this android/ folder.

storeFile=release-key.jks
storePassword=change-me
keyAlias=budgeteer
keyPassword=change-me
